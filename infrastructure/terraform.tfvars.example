# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your actual values

cloudflare_api_token   = "your-cloudflare-api-token-here"
cloudflare_account_id  = "your-cloudflare-account-id-here"
domain_zone            = "thijsvtol.nl"
subdomain              = "photos"
r2_bucket_name         = "photos-storage"
r2_location            = "WEUR"
d1_database_name       = "photos-db"
worker_name            = "photos-worker"
worker_compatibility_date = "2024-09-23"
