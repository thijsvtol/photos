# Worker Environment Variables
# Copy this file to .env for local development

# Required: Application Branding
APP_NAME="Photos"
BRAND_NAME="Photos"
COPYRIGHT_HOLDER="Your Name"

# Required: Domain Configuration
APP_DOMAIN="photos.yourdomain.com"
CONTACT_EMAIL="contact@yourdomain.com"

# Required: Secrets (generate secure random strings)
EVENT_COOKIE_SECRET="your-secret-key-here-min-32-chars"
JWT_SECRET="your-jwt-secret-here-min-32-chars"
ADMIN_EMAILS="admin@yourdomain.com,admin2@yourdomain.com"

# Optional: Email Integration (Mailgun)
# Required for collaborator invitations
# MAILGUN_API_KEY="your-mailgun-api-key"
# MAILGUN_DOMAIN="mg.yourdomain.com"

# Environment
ENVIRONMENT="development"

# Cloudflare Bindings (automatically provided in production)
# D1 Database: DB
# R2 Bucket: PHOTOS_BUCKET
