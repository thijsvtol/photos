# Frontend Environment Variables
# Copy this file to .env for local development

# Required: API URL (points to your Cloudflare Worker)
VITE_API_URL="http://localhost:8787"

# Optional: Override branding at build time (usually injected by worker at runtime)
# VITE_APP_NAME="Photos"
# VITE_BRAND_NAME="Photos"
# VITE_COPYRIGHT_HOLDER="Your Name"
# VITE_DOMAIN="photos.yourdomain.com"
# VITE_CONTACT_EMAIL="contact@yourdomain.com"

# Optional: Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Get this from: https://analytics.google.com/ > Admin > Data Streams > Web Stream Details
VITE_GA_MEASUREMENT_ID="G-PLACEHOLDER"
