{
  "name": "photos-web",
  "version": "1.4.0",
  "description": "React frontend for photo sharing application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "playwright install"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capawesome/capacitor-background-task": "^8.0.0",
    "@capawesome/capacitor-file-picker": "8.0.1",
    "@formspree/react": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.7.9",
    "dexie": "^4.0.10",
    "exifreader": "^4.25.0",
    "filerobot-image-editor": "^4.8.1",
    "jszip": "^3.10.1",
    "konva": "^10.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-filerobot-image-editor": "^5.0.1",
    "react-helmet-async": "^3.0.0",
    "react-konva": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.13.2",
    "styled-components": "^6.3.12",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.0.18"
  }
}
