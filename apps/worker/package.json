{
  "name": "photos-worker",
  "version": "1.4.4",
  "description": "Cloudflare Worker backend for photo sharing application",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc -p tsconfig.json",
    "deploy": "wrangler deploy",
    "test": "vitest run --passWithNoTests",
    "test:coverage:security": "vitest run src/test/securityRoutesCoverage.test.ts --coverage --coverage.include=src/routes/media.ts --coverage.include=src/routes/zip.ts --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100",
    "test:integration:staging": "vitest run src/test/stagingIntegration.test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "form-data": "^4.0.5",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "mailgun.js": "^12.7.1",
    "ulid": "^3.0.2"
  }
}
